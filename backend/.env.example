# Moranguinho Stock Manager - Configuração
APP_NAME=Moranguinho Stock Manager
APP_ENV=development
DEBUG=true

# Banco de dados (SQLite dev / PostgreSQL prod)
DATABASE_URL=sqlite:///./moranguinho.db
# DATABASE_URL=postgresql://user:password@localhost:5432/moranguinho

# JWT
SECRET_KEY=altere-esta-chave-secreta-em-producao-moranguinho-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# OpenAI (MorangIA) - opcional, funciona offline sem chave
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880

# CORS
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000
